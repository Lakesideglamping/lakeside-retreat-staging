# ===============================
# LAKESIDE RETREAT - PRODUCTION ENVIRONMENT TEMPLATE
# ===============================
# 
# SECURITY NOTICE:
# - Never commit this file with real values to version control
# - Use Render.com environment variables for production deployment
# - Generate new secrets for production (don't use development secrets)
#
# Setup Instructions:
# 1. Copy this template to .env.production (not tracked by git)
# 2. Replace all placeholder values with real production values
# 3. Configure these same variables in Render.com environment settings
# ===============================

# Server Configuration
NODE_ENV=production
PORT=10000
TRUST_PROXY=true

# Security Secrets - GENERATE NEW ONES FOR PRODUCTION
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERATE_NEW_64_CHAR_SECRET_FOR_PRODUCTION
SESSION_SECRET=GENERATE_NEW_64_CHAR_SECRET_FOR_PRODUCTION

# Admin Authentication - CONFIGURE UNIQUE VALUES
ADMIN_USERNAME=your_unique_admin_username
ADMIN_PASSWORD_HASH=GENERATE_BCRYPT_HASH_OF_STRONG_PASSWORD
JWT_EXPIRY=1h

# Database Configuration
DATABASE_URL=sqlite:./lakeside.db

# Rate Limiting (Production Values)
LOGIN_RATE_LIMIT_ATTEMPTS=3
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
BCRYPT_ROUNDS=12

# Stripe Configuration - USE PRODUCTION KEYS
STRIPE_SECRET_KEY=sk_live_YOUR_PRODUCTION_STRIPE_SECRET_KEY
STRIPE_PUBLIC_KEY=pk_live_YOUR_PRODUCTION_STRIPE_PUBLIC_KEY  
STRIPE_WEBHOOK_SECRET=whsec_YOUR_PRODUCTION_WEBHOOK_SECRET

# Uplisting Integration - GET NEW API KEYS FROM UPLISTING
UPLISTING_API_KEY=GET_NEW_API_KEY_FROM_UPLISTING_DASHBOARD
UPLISTING_WEBHOOK_SECRET=GENERATE_NEW_WEBHOOK_SECRET
UPLISTING_API_URL=https://api.uplisting.io/v1
UPLISTING_SYNC_ENABLED=true
UPLISTING_TIMEOUT=10000
UPLISTING_RETRY_ATTEMPTS=3

# Uplisting Property IDs (Verify these are correct)
UPLISTING_COTTAGE_ID=80360
UPLISTING_ROSE_ID=82754
UPLISTING_PINOT_ID=82753

# SSL Configuration (if using custom SSL)
# SSL_KEY_PATH=/path/to/private-key.pem
# SSL_CERT_PATH=/path/to/certificate.pem
# SSL_CA_PATH=/path/to/ca-bundle.pem
# HTTPS_ONLY=true

# Monitoring & Logging
LOG_LEVEL=info

# ===============================
# RENDER.COM DEPLOYMENT NOTES:
# ===============================
# 
# Set these environment variables in Render.com dashboard:
# 1. Go to your service settings
# 2. Navigate to Environment section  
# 3. Add each variable above with production values
# 4. DO NOT use the values from this template file
# 
# Critical: Generate new secrets for production!
# ===============================